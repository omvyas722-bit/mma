# Docker environment variables
# Copy this file to .env and fill in your values

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long-change-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost

# Email Configuration (Brevo SMTP)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_email@example.com
SMTP_PASS=your_brevo_smtp_key
SMTP_FROM=noreply@roarmma.com.au

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+61400000000

# AI Configuration (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key

# Lightspeed Configuration
LIGHTSPEED_WEBHOOK_SECRET=your_lightspeed_webhook_secret
