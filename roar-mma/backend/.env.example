# Server Configuration
PORT=3001
HOST=localhost
NODE_ENV=development

# Database
DATABASE_PATH=../data/roarmma.db

# JWT Authentication
JWT_SECRET=change-this-to-a-random-secret-key-min-32-chars

# CORS
CORS_ORIGIN=http://localhost:5173

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_FROM_NUMBER=+61412345678

# Brevo Email Configuration
BREVO_API_KEY=YOUR_BREVO_API_KEY
BREVO_FROM_EMAIL=info@roarmma.com.au
BREVO_FROM_NAME=ROAR MMA

# Gym Information
GYM_NAME=ROAR MMA
GYM_PHONE=(08) 9999 9999
GYM_LOCATION=Rockingham
BOOKING_URL=https://roarmma.com.au/book
SCHEDULE_URL=https://roarmma.com.au/schedule
DEFAULT_STAFF_NAME=ROAR Team

# Business Hours (for AI phone routing)
BUSINESS_HOURS_START=06:00
BUSINESS_HOURS_END=21:00
BUSINESS_DAYS=1,2,3,4,5,6

# Rate Limiting
SMS_RATE_LIMIT_PER_DAY=5
EMAIL_RATE_LIMIT_PER_DAY=10

# Logging
LOG_LEVEL=info

# AI Providers (OpenRouter primary, others are fallbacks)
OPENROUTER_API_KEY=your_openrouter_api_key_here
GROQ_API_KEY=your_groq_api_key_here
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=
