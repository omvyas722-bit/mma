# Server Configuration
PORT=3001
HOST=localhost
NODE_ENV=development

# Database
DATABASE_PATH=../data/roarmma.db

# JWT Authentication - CHANGE THIS to a random 64-char hex string
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# CORS
CORS_ORIGIN=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+61412345678

# Brevo Email Configuration
BREVO_API_KEY=your_brevo_api_key
BREVO_FROM_EMAIL=info@roarmma.com.au
BREVO_FROM_NAME=ROAR MMA

# Gym Information
GYM_NAME=ROAR MMA
GYM_PHONE=(08) 9999 9999
GYM_LOCATION=Rockingham
BOOKING_URL=https://roarmma.com.au/book
SCHEDULE_URL=https://roarmma.com.au/schedule
DEFAULT_STAFF_NAME=ROAR Team

# Business Hours (for AI phone routing)
BUSINESS_HOURS_START=06:00
BUSINESS_HOURS_END=21:00
BUSINESS_DAYS=1,2,3,4,5,6

# Rate Limiting
SMS_RATE_LIMIT_PER_DAY=5
EMAIL_RATE_LIMIT_PER_DAY=10

# Sentry error tracking
SENTRY_DSN=https://example@sentry.example.com/123
VITE_SENTRY_DSN=https://example@sentry.example.com/123

# Logging
LOG_LEVEL=info

# AI Providers (OpenRouter primary, others are fallbacks)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_DAILY_LIMIT=50
OPENROUTER_MAX_RPM=20
OPENROUTER_MAX_RETRIES=3
OPENROUTER_TIMEOUT_MS=30000
GROQ_API_KEY=your_groq_api_key_here
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=
